# Gmail SMTP 인증 정보 (강사용)
#
# ⚠️ 반드시 "앱 비밀번호"를 써야 합니다. 일반 Gmail 비밀번호는 Google이 보안상 차단.
#
# 사전 준비:
#   1. Google 계정 2FA 활성화: https://myaccount.google.com/security
#   2. 앱 비밀번호 발급: https://myaccount.google.com/apppasswords
#      - 앱 이름: "Claude Code week07 demo" (자유)
#      - 생성된 16자리 비밀번호를 아래에 붙여넣기 (공백 포함/제거 둘 다 동작)
#   3. 이 파일을 .env로 복사 후 값 채우기
#
# .env 파일은 git에 포함되지 않음 (.gitignore 처리됨)

# ─── F1 샘플 메일 발송 + F2 실제 발송에 쓰이는 "발신 계정" ───
# 이 계정으로 SMTP 로그인해서 메일을 보냄. 앱 비밀번호 필수.
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── F2 수신 테스트용 "수신 계정들" (쉼표 구분, 비밀번호 불필요) ───
# 강사 본인의 부계정이나 다른 메일 주소. SMTP는 "받기만" 하므로 비밀번호 불필요.
SUB_ACCOUNTS=sub1@gmail.com,sub2@gmail.com

# ─── DART (금융감독원 전자공시시스템) API 키 ───
# 데모 B에서 삼성전자 재무제표 조회에 사용.
# 발급: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do (무료·즉시)
# 없으면 샘플 데이터로 폴백.
#
# 참고: week06-hands-on/.env 에 이미 발급된 키가 있으면
#       fallback_analysis.py가 자동으로 거기서도 읽어옴 (week07에 복붙 불필요).
DART_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
